.aws/
.azure/
.gcp/
gcp-key*.json
google-service-account*.json
firebase-adminsdk*.json

# Tooling tokens and local auth
.npmrc
.yarnrc.yml
.pnpmrc
.netrc

# App/runtime secret outputs
pids
*.pid
*.pid.lock

