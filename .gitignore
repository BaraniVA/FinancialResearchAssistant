# ----------------------------------------------------------------------------
# Secrets and credentials (prevent accidental leaks)
# ----------------------------------------------------------------------------

# Any env variants
.env.*
!.env.example
!.env.sample

# Generic secret/config files
*.secret
*.secrets
secrets.*
secret.*

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
*.asc
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

